{
  "$schema": "vscode://schemas/color-theme",
  "name": "NVECode Dark",
  "type": "dark",
  "colors": {
    "editor.background":                     "#0d1117",
    "editor.foreground":                     "#c8d3e6",
    "editorLineNumber.foreground":           "#1e2536",
    "editorLineNumber.activeForeground":     "#3d4d68",
    "editor.lineHighlightBackground":        "#111520",
    "editor.selectionBackground":            "#1e2d50",
    "editor.inactiveSelectionBackground":    "#192340",
    "editor.wordHighlightBackground":        "#1a2540",
    "editorCursor.foreground":               "#4a9eff",
    "editorIndentGuide.background":          "#161b24",
    "editorIndentGuide.activeBackground":    "#1e2536",
    "editorBracketMatch.background":         "#1e2d5044",
    "editorBracketMatch.border":             "#2d4880",
    "editorGutter.background":               "#0d1117",
    "editorGutter.addedBackground":          "#3dd68c44",
    "editorGutter.modifiedBackground":       "#4a9eff44",
    "editorGutter.deletedBackground":        "#ff555544",
    "editorOverviewRuler.border":            "#161b24",
    "editorWidget.background":               "#111520",
    "editorWidget.border":                   "#1e2536",
    "editorSuggestWidget.background":        "#111520",
    "editorSuggestWidget.border":            "#1e2536",
    "editorSuggestWidget.selectedBackground":"#1e2d40",
    "editorSuggestWidget.highlightForeground":"#4a9eff",
    "editorHoverWidget.background":          "#111520",
    "editorHoverWidget.border":              "#1e2536",
    "activityBar.background":                "#0d1117",
    "activityBar.foreground":                "#3d4d68",
    "activityBar.activeBorder":              "#4a9eff",
    "activityBar.border":                    "#161b24",
    "activityBarBadge.background":           "#4a9eff",
    "activityBarBadge.foreground":           "#ffffff",
    "sideBar.background":                    "#0d1117",
    "sideBar.foreground":                    "#6a7a9a",
    "sideBar.border":                        "#161b24",
    "sideBarTitle.foreground":               "#3d4d68",
    "sideBarSectionHeader.background":       "#0d1117",
    "sideBarSectionHeader.border":           "#161b24",
    "list.hoverBackground":                  "#111520",
    "list.activeSelectionBackground":        "#1a2540",
    "list.inactiveSelectionBackground":      "#141924",
    "list.focusBackground":                  "#1a2540",
    "list.highlightForeground":              "#4a9eff",
    "titleBar.activeBackground":             "#0d1117",
    "titleBar.activeForeground":             "#6a7a9a",
    "titleBar.inactiveBackground":           "#0d1117",
    "titleBar.border":                       "#161b24",
    "tab.activeBackground":                  "#0d1117",
    "tab.activeForeground":                  "#c8d3e6",
    "tab.activeBorderTop":                   "#4a9eff",
    "tab.inactiveBackground":                "#0d1117",
    "tab.inactiveForeground":                "#3d4d68",
    "tab.border":                            "#161b24",
    "editorGroupHeader.tabsBackground":      "#0d1117",
    "editorGroupHeader.tabsBorder":          "#161b24",
    "statusBar.background":                  "#0d1117",
    "statusBar.foreground":                  "#3d4d68",
    "statusBar.border":                      "#161b24",
    "statusBarItem.hoverBackground":         "#161b24",
    "statusBarItem.remoteBackground":        "#4a9eff",
    "statusBarItem.remoteForeground":        "#ffffff",
    "panel.background":                      "#0d1117",
    "panel.border":                          "#161b24",
    "panelTitle.activeForeground":           "#c8d3e6",
    "panelTitle.activeBorder":               "#4a9eff",
    "panelTitle.inactiveForeground":         "#3d4d68",
    "terminal.background":                   "#0d1117",
    "terminal.foreground":                   "#c8d3e6",
    "terminal.ansiBlack":                    "#1e2536",
    "terminal.ansiBlue":                     "#4a9eff",
    "terminal.ansiBrightBlue":               "#79b8ff",
    "terminal.ansiCyan":                     "#39c5cf",
    "terminal.ansiBrightCyan":               "#56d4dd",
    "terminal.ansiGreen":                    "#3dd68c",
    "terminal.ansiBrightGreen":              "#56e5a1",
    "terminal.ansiMagenta":                  "#b392f0",
    "terminal.ansiBrightMagenta":            "#c9acf7",
    "terminal.ansiRed":                      "#ff5555",
    "terminal.ansiBrightRed":                "#ff7777",
    "terminal.ansiYellow":                   "#f9c513",
    "terminal.ansiBrightYellow":             "#ffd85e",
    "terminal.ansiWhite":                    "#c8d3e6",
    "terminal.ansiBrightWhite":              "#e8edf7",
    "terminalCursor.foreground":             "#4a9eff",
    "input.background":                      "#0d1117",
    "input.border":                          "#1e2536",
    "input.foreground":                      "#c8d3e6",
    "input.placeholderForeground":           "#2a3040",
    "button.background":                     "#4a9eff",
    "button.foreground":                     "#ffffff",
    "button.hoverBackground":                "#3a8eef",
    "focusBorder":                           "#4a9eff",
    "foreground":                            "#c8d3e6",
    "descriptionForeground":                 "#4a5568",
    "textLink.foreground":                   "#4a9eff",
    "scrollbarSlider.background":            "#1e253655",
    "scrollbarSlider.hoverBackground":       "#1e253688",
    "minimap.background":                    "#0d1117",
    "diffEditor.insertedLineBackground":     "#3dd68c08",
    "diffEditor.removedLineBackground":      "#ff555508",
    "gitDecoration.addedResourceForeground":    "#3dd68c",
    "gitDecoration.modifiedResourceForeground": "#4a9eff",
    "gitDecoration.deletedResourceForeground":  "#ff5555",
    "gitDecoration.ignoredResourceForeground":  "#2a3040"
  },
  "tokenColors": [
    { "scope": ["comment"],                "settings": { "foreground": "#263040", "fontStyle": "italic" }},
    { "scope": ["keyword", "storage.type","storage.modifier"], "settings": { "foreground": "#b392f0" }},
    { "scope": ["keyword.operator"],       "settings": { "foreground": "#79b8ff" }},
    { "scope": ["string"],                 "settings": { "foreground": "#9ecbff" }},
    { "scope": ["string.regexp"],          "settings": { "foreground": "#39c5cf" }},
    { "scope": ["constant.numeric"],       "settings": { "foreground": "#f9c513" }},
    { "scope": ["constant.language"],      "settings": { "foreground": "#f9c513" }},
    { "scope": ["entity.name.function","support.function"], "settings": { "foreground": "#79b8ff" }},
    { "scope": ["entity.name.type","entity.name.class","support.type","support.class"], "settings": { "foreground": "#f9c513" }},
    { "scope": ["variable"],               "settings": { "foreground": "#c8d3e6" }},
    { "scope": ["variable.language"],      "settings": { "foreground": "#b392f0", "fontStyle": "italic" }},
    { "scope": ["variable.parameter"],     "settings": { "foreground": "#d1acf7" }},
    { "scope": ["entity.name.tag"],        "settings": { "foreground": "#ff5555" }},
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#f9c513" }},
    { "scope": ["support.constant"],       "settings": { "foreground": "#f9c513" }},
    { "scope": ["constant.character.escape"], "settings": { "foreground": "#39c5cf" }},
    { "scope": ["meta.preprocessor","entity.name.namespace"], "settings": { "foreground": "#b392f0" }},
    { "scope": ["markup.heading"],         "settings": { "foreground": "#79b8ff", "fontStyle": "bold" }},
    { "scope": ["markup.bold"],            "settings": { "foreground": "#f9c513", "fontStyle": "bold" }},
    { "scope": ["markup.italic"],          "settings": { "fontStyle": "italic" }},
    { "scope": ["markup.inline.raw"],      "settings": { "foreground": "#9ecbff" }},
    { "scope": ["invalid.illegal"],        "settings": { "foreground": "#ff5555", "fontStyle": "underline" }},
    { "scope": ["punctuation"],            "settings": { "foreground": "#2a3a54" }},
    { "scope": ["meta.object-literal.key"],"settings": { "foreground": "#79b8ff" }},
    { "scope": ["meta.decorator"],         "settings": { "foreground": "#f9c513" }}
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace":         "#f9c513",
    "class":             "#f9c513",
    "struct":            "#f9c513",
    "interface":         { "foreground": "#f9c513", "fontStyle": "italic" },
    "enum":              "#f9c513",
    "enumMember":        "#f9c513",
    "function":          "#79b8ff",
    "method":            "#79b8ff",
    "macro":             { "foreground": "#b392f0", "fontStyle": "bold" },
    "variable.readonly": "#f9c513",
    "parameter":         "#d1acf7",
    "property":          "#9ecbff",
    "keyword":           "#b392f0",
    "comment":           { "foreground": "#263040", "fontStyle": "italic" },
    "lifetime":          { "foreground": "#f9c513", "fontStyle": "italic" },
    "selfKeyword":       { "foreground": "#b392f0", "fontStyle": "italic" }
  }
}

